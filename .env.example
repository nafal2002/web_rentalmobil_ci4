# CI ENVIRONMENT
CI_ENVIRONMENT = development

# APP
app.baseURL = 'http://localhost:8080/'
app.forceGlobalSecureRequests = false
app.sessionDriver = 'CodeIgniter\\Session\\Handlers\\FileHandler'
app.sessionCookieName = 'ci_session'
app.sessionExpiration = 7200
app.sessionSavePath = null
app.sessionMatchIP = false
app.sessionTimeToUpdate = 300
app.sessionRegenerateDestroy = false
app.cookiePrefix = ''
app.cookieSecure = false
app.cookieHttpOnly = true
app.cookieSameSite = 'Lax'
app.cookieDomain = ''
app.cookiePath = '/'
app.CSRFProtection = true
app.CSRFTokenRandomize = false
app.CSRFHeaderName = 'X-CSRF-TOKEN'
app.CSRFCookieName = 'csrf_cookie_name'

# DATABASE
database.default.hostname = localhost
database.default.database = db_rentalmobil
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

# ENCRYPTION
encryption.key =
encryption.driver = OpenSSL

# PAYMENT GATEWAY - MIDTRANS
MIDTRANS_MERCHANT_ID = your_merchant_id
MIDTRANS_CLIENT_KEY = your_client_key
MIDTRANS_SERVER_KEY = your_server_key
MIDTRANS_ENV = sandbox

# PAYMENT GATEWAY - STRIPE
STRIPE_PUBLIC_KEY = your_public_key
STRIPE_SECRET_KEY = your_secret_key

# NOTIFICATION - TWILIO (SMS)
TWILIO_ACCOUNT_SID = your_account_sid
TWILIO_AUTH_TOKEN = your_auth_token
TWILIO_PHONE_NUMBER = your_twilio_number

# NOTIFICATION - WHATSAPP
WHATSAPP_API_URL = https://graph.instagram.com/v18.0/your_phone_number_id/messages
WHATSAPP_TOKEN = your_whatsapp_token

# NOTIFICATION - EMAIL
SMTP_HOST = smtp.gmail.com
SMTP_USER = your_email@gmail.com
SMTP_PASS = your_email_password
SMTP_PORT = 587
MAIL_FROM = noreply@rentalmobil.com
APP_NAME = Rental Mobil

# LOGGING
log.threshold = 4
log.dateFormat = Y-m-d H:i:s

# SECURITY
SECURE_COOKIES = false
